[phases.setup]
nixPkgs = ["python312"]

[phases.install]
cmds = [
  "pip install --no-cache-dir --upgrade pip",
  "pip install --no-cache-dir -r requirements.txt"
]

[phases.build]
cmds = [
  "echo 'Build phase complete'"
]

[start]
cmd = "uvicorn server.main:app --host 0.0.0.0 --port ${PORT:-8000}"

[variables]
PYTHON_VERSION = "3.12"
PORT = "8000"
